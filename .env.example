# Anthropic API — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot — create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# GitHub — create at https://github.com/settings/tokens (needs repo scope)
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-username/venezuela-currency-agent

# FRED (St Louis Fed) — free key from https://fredaccount.stlouisfed.org/apikeys
# Used by scrapers/oil_fetcher.py to pull Brent crude (DCOILBRENTEU) for the Stage 3 forecaster.
FRED_API_KEY=...
